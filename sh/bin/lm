# Clear the display
clear

# Display the current working directory if no argument is given
if [ $# -eq 0 ]; then
    $0 "$(pwd)"
    exit
fi

# Colors to make a more readable output
dirCol="\e[40;7m"
resetColor="\e[0m"

# While there are arguments
while test $# -ne 0; do
  # Getting the full path the given file or dir
  if test -d "$1";  then
    source=$(cd -P "$1" && pwd)
    # If the path is not the root, add a '/' at the end to mark it as a path
    if test "$source" != "/"; then
      source="$source/"
    fi
  else
    source="$(cd -P $(dirname $1) && pwd)/$(basename $1)"
  fi

  # Display the selected dir if necessary
  if test -d "$source"; then
    printf "${dirCol}${source}${resetColor}\n"
  fi
  # Display the content of the wanted dir
  ls -lhaFG "$source"

  shift
done

unset dirCol
unset resetColor
unset source
