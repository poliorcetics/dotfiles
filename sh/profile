# https://stackoverflow.com/questions/3601515/how-to-check-if-a-variable-is-set-in-bash
if test -z ${DIRCONFIG+x}; then
  DIRCONFIG=$HOME/.config
  export DIRCONFIG
fi
test -d $DIRCONFIG || mkdir -p $DIRCONFIG

# Loading the basic file
source $DIRCONFIG/sh/common/basic.sh

# Loading the optional modules
for option in `find $DIRCONFIG/sh/options -maxdepth 1 -iname "[^.]*[^.md]" -type f`; do
  _mod=$DIRCONFIG/sh/common/modules/$(basename $option).sh
  source $_mod 2>/dev/null || echo "Failed to load module $_mod" >&2
done
unset _mod

# If the user has a personal bin directory, use it as first element in the path
# Else, avoid cluttering the path
if test -d $HOME/bin; then
  case :$PATH: in
    *:$HOME/bin:*)
      ;;
    *)
      PATH=$HOME/bin:$PATH
      export PATH
      ;;
  esac
fi
if test -d $HOME/.bin; then
  case :$PATH: in
    *:$HOME/.bin:*)
      ;;
    *)
      PATH=$HOME/.bin:$PATH
      export PATH
      ;;
  esac
fi
if test -d $DIRCONFIG/sh/bin; then
  case :$PATH: in
    *:$DIRCONFIG/sh/bin:*)
      ;;
    *)
      PATH=$DIRCONFIG/sh/bin:$PATH
      export PATH
      ;;
  esac
fi

# Shell specific file
shell_rc=""
if ! test -z ${ZSH_NAME+x}; then
  shell_rc=$DIRCONFIG/sh/zsh/zshrc
elif ! test -z ${BASH+x}; then
  shell_rc=$DIRCONFIG/sh/bash/bashrc
fi
source $shell_rc 2>/dev/null || echo "Could not load rc file: $shell_rc" >&2
unset shell_rc
