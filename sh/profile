# https://stackoverflow.com/questions/3601515/how-to-check-if-a-variable-is-set-in-bash
if builtin test -z ${DIRCONFIG+x}; then
  DIRCONFIG=$HOME/.config
  builtin export DIRCONFIG
fi
builtin test -d $DIRCONFIG || mkdir -p $DIRCONFIG

# Loading the basic file
builtin source $DIRCONFIG/sh/common/basic.sh

# Loading the optional modules
for option in `find $DIRCONFIG/sh/options -type f -iname "[^.]*[^.md]" -depth 1`; do
  _mod=$DIRCONFIG/sh/common/modules/$(basename $option).sh
  builtin source $_mod 2>/dev/null || builtin echo "Failed to load module $_mod" >&2
done
builtin unset _mod

# Shell specific file
shell_rc=""
if ! builtin test -z ${ZSH_NAME+x}; then
  shell_rc=$DIRCONFIG/sh/zsh/zshrc
elif ! builtin test -z ${BASH+x}; then
  shell_rc=$DIRCONFIG/sh/bash/bashrc
fi
builtin source $shell_rc 2>/dev/null || builtin echo "Could not load rc file: $shell_rc" >&2
builtin unset shell_rc

# If the user has a personal bin directory, use it as first element in the path
# Else, avoid cluttering the path
if builtin test -d $HOME/bin; then
  case :$PATH: in
    *:$HOME/bin:*)
      ;;
    *)
      PATH=$HOME/bin:$PATH
      builtin export PATH
      ;;
  esac
fi
if builtin test -d $HOME/.bin; then
  case :$PATH: in
    *:$HOME/.bin:*)
      ;;
    *)
      PATH=$HOME/.bin:$PATH
      builtin export PATH
      ;;
  esac
fi
